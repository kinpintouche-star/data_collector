//@version=6
strategy("ICT CRT M1 Strategy v1.6 - Clean", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=300, max_bars_back=1500, initial_capital=100000, default_qty_type=strategy.fixed, default_qty_value=1, commission_type=strategy.commission.percent, commission_value=0.0, process_orders_on_close=true, calc_on_every_tick=false, margin_long=1, margin_short=1)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 0. OBJECTIF DU SCRIPT
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// Stratégie backtestable TradingView.
// Chaîne : H1 C2/C3 → double swing M15 → jambe M1 → Fibo/OTE → OB solide ou FVG dans OTE → mitigation/rejet → ordre.
// Version v1.6 CLEAN : logique stabilisée, table allégée, exécution fixe, diagnostic minimal.
// La logique de trading reste identique à la v1.5 validée : elle détecte les trades puis envoie strategy.entry/exit.
// À utiliser prioritairement sur graphique M1.

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 1. INPUTS PRINCIPAUX
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

tz = input.string("America/New_York", "Fuseau horaire", options=["America/New_York", "Europe/Paris", "Europe/Berlin"])
onlyKZ = input.bool(true, "C2/C3 seulement en killzone")
kz1s = input.int(1, "KZ London début", minval=0, maxval=23)
kz1e = input.int(5, "KZ London fin", minval=0, maxval=24)
kz2s = input.int(7, "KZ NY début", minval=0, maxval=23)
kz2e = input.int(11, "KZ NY fin", minval=0, maxval=24)
detC3 = input.bool(true, "Détecter C3 englobante")
tradeDirection = input.string("Auto", "Sens autorisé", options=["Auto", "Bullish uniquement", "Bearish uniquement"])
strategyMode = input.string("A - Invalidation S2", "Mode de test", options=["A - Invalidation S2", "B - Pas d'invalidation S2", "C - S2 intérieur S1"])
assetType = input.string("Index", "Type d'actif", options=["Forex", "Index", "Crypto", "Commodity", "Futures", "Stock", "Other"])
showDebugVisuals = input.bool(false, "Afficher visuels sur le graphique")
showTable = input.bool(true, "Afficher table stats interne")
orderQty = input.float(1.0, "Quantité par trade", minval=0.001, step=0.001, group="Exécution")

invalidateBeyondS2 = strategyMode == "A - Invalidation S2" or strategyMode == "C - S2 intérieur S1"
requireS2InsideS1 = strategyMode == "C - S2 intérieur S1"

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 2. INPUTS M15 / FIBO / OTE
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

oteDeep = input.float(0.79, "OTE niveau profond", minval=0.70, maxval=0.90, step=0.001)
fibForwardMinutes = input.int(180, "Projection Fibo minutes", minval=30, maxval=1440)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 3. INPUTS PD ARRAY / OB SOLIDE
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

pdMode = input.string("OB solide ou FVG", "Mode PD Array", options=["OB solide", "FVG", "OB solide ou FVG"])
obSensitivityMode = input.string("ATR adaptive", "OB sensibilité : mode", options=["ATR adaptive", "Percent"])
obAtrLen = input.int(14, "OB ATR length", minval=1)
ob1Sensitivity = input.float(5.0, "OB1 sensibilité", minval=0.1, step=0.1)
ob2Sensitivity = input.float(8.0, "OB2 sensibilité", minval=0.1, step=0.1)
obMinBodyRatio = input.float(0.55, "OB solide : body/range min", minval=0.10, maxval=1.00, step=0.05)
obLookback1 = input.int(10, "OB1 recherche bougies opposées", minval=1, maxval=30)
obLookback2From = input.int(4, "OB2 début recherche", minval=1, maxval=30)
obLookback2To = input.int(15, "OB2 fin recherche", minval=2, maxval=50)
pdRequireMidInOTE = input.bool(true, "PD Array : midpoint dans OTE")
slBufferTicks = input.int(2, "SL buffer ticks", minval=0, maxval=100)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 4. HELPERS
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

f_price(float p) => str.tostring(p, format.mintick)

f_inKZ(int t, int bufMin) =>
    int md = na(t) ? -1 : hour(t, tz) * 60 + minute(t, tz)
    bool in1 = md >= kz1s * 60 - bufMin and md < kz1e * 60
    bool in2 = md >= kz2s * 60 - bufMin and md < kz2e * 60
    in1 or in2

f_level(float startPrice, float endPrice, float lvl) =>
    float r = math.abs(endPrice - startPrice)
    endPrice > startPrice ? endPrice - r * lvl : endPrice + r * lvl

f_in_zone(float value, float zLo, float zHi) =>
    value >= zLo and value <= zHi

f_zone_overlap(float topA, float botA, float topB, float botB) =>
    math.max(botA, botB) <= math.min(topA, topB)

f_ob_solid(int i) =>
    float r = high[i] - low[i]
    float b = math.abs(close[i] - open[i])
    r > 0 and b / r >= obMinBodyRatio

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 5. REGISTRE VISUEL
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

var line[] allLines = array.new_line()
var label[] allLabels = array.new_label()
var box[] allBoxes = array.new_box()

f_add_line(line l) =>
    array.push(allLines, l)

f_add_label(label lb) =>
    array.push(allLabels, lb)

f_add_box(box b) =>
    array.push(allBoxes, b)

f_clear_visuals() =>
    int i = array.size(allLines) - 1
    while i >= 0
        line.delete(array.get(allLines, i))
        array.remove(allLines, i)
        i -= 1
    int j = array.size(allLabels) - 1
    while j >= 0
        label.delete(array.get(allLabels, j))
        array.remove(allLabels, j)
        j -= 1
    int k = array.size(allBoxes) - 1
    while k >= 0
        box.delete(array.get(allBoxes, k))
        array.remove(allBoxes, k)
        k -= 1

f_draw_hline(int x1, int x2, float p, string txt, color c) =>
    line l = line.new(x1, p, x2, p, xloc=xloc.bar_time, extend=extend.none, color=c, width=1)
    label lb = label.new(x2, p, txt, xloc=xloc.bar_time, yloc=yloc.price, style=label.style_none, textcolor=c, size=size.tiny)
    f_add_line(l)
    f_add_label(lb)

f_draw_fib(int x1, int x2, float startPrice, float endPrice) =>
    float p0 = f_level(startPrice, endPrice, 0.0)
    float p50 = f_level(startPrice, endPrice, 0.5)
    float p618 = f_level(startPrice, endPrice, 0.618)
    float p705 = f_level(startPrice, endPrice, 0.705)
    float p79 = f_level(startPrice, endPrice, oteDeep)
    float p1 = f_level(startPrice, endPrice, 1.0)
    float zTop = math.max(p618, p79)
    float zBot = math.min(p618, p79)
    box b = box.new(x1, zTop, x2, zBot, xloc=xloc.bar_time, border_color=color.new(color.orange, 0), bgcolor=color.new(color.orange, 85))
    f_add_box(b)
    f_draw_hline(x1, x2, p0, "0", color.white)
    f_draw_hline(x1, x2, p50, "0.5", color.gray)
    f_draw_hline(x1, x2, p618, "0.618", color.orange)
    f_draw_hline(x1, x2, p705, "0.705", color.orange)
    f_draw_hline(x1, x2, p79, str.tostring(oteDeep), color.orange)
    f_draw_hline(x1, x2, p1, "1", color.white)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 6. H1 : DÉTECTION C2 / C3
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// C2 = sweep + clôture de retour dans le range C1.
// C3 = sweep + clôture au-delà du range C1 si l'option est activée.

sym = syminfo.tickerid
onM1 = timeframe.in_seconds(timeframe.period) == 60

[c2h, c2l, c2c, c2t, c1h, c1l] = request.security(sym, "60", [high[1], low[1], close[1], time[1], high[2], low[2]], lookahead=barmerge.lookahead_off)

isNewH1 = ta.change(c2t) != 0
okKZ = onlyKZ ? f_inKZ(c2t, 0) : true
backInC1 = not na(c1h) and not na(c1l) and c2c > c1l and c2c < c1h
sweptHigh = c2h > c1h
sweptLow = c2l < c1l
c1mid = (c1h + c1l) / 2.0

bearC2 = backInC1 and sweptHigh and (not sweptLow or c2c < c1mid)
bullC2 = backInC1 and sweptLow and (not sweptHigh or c2c >= c1mid)
bearC3 = detC3 and not na(c1l) and sweptHigh and c2c < c1l
bullC3 = detC3 and not na(c1h) and sweptLow and c2c > c1h

bearSig = bearC2 or bearC3
bullSig = bullC2 or bullC3
allowBull = tradeDirection != "Bearish uniquement"
allowBear = tradeDirection != "Bullish uniquement"
newSignal = onM1 and isNewH1 and okKZ and strategy.position_size == 0 and ((bullSig and allowBull) or (bearSig and allowBear))

c2open = c2t

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 7. M1 : RECONSTRUCTION DES PIVOTS M15
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// Le script tourne en M1, mais reconstruit les pivots M15.
// Ces pivots donnent S1/S2 et la fin de jambe.

m15ot = request.security(sym, "15", time, lookahead=barmerge.lookahead_off)
m15h1 = request.security(sym, "15", high[1], lookahead=barmerge.lookahead_off)
m15l1 = request.security(sym, "15", low[1], lookahead=barmerge.lookahead_off)
m15t1 = request.security(sym, "15", time[1], lookahead=barmerge.lookahead_off)
newM15 = ta.change(m15ot) != 0

var float Ha = na
var int Hat = na
var float Hb = na
var int Hbt = na
var float Hc = na
var float La = na
var int Lat = na
var float Lb = na
var int Lbt = na
var float Lc = na

float mPH = na
int mPHt = na
float mPL = na
int mPLt = na

if onM1 and newM15
    Hc := Hb
    Hb := Ha
    Hbt := Hat
    Ha := m15h1
    Hat := m15t1
    Lc := Lb
    Lb := La
    Lbt := Lat
    La := m15l1
    Lat := m15t1
    if not na(Hc) and Hb > Ha and Hb > Hc
        mPH := Hb
        mPHt := Hbt
    if not na(Lc) and Lb < La and Lb < Lc
        mPL := Lb
        mPLt := Lbt

var float mLPH = na
var int mLPHt = na
var float mPPH = na
var int mPPHt = na

if onM1 and not na(mPH)
    mPPH := mLPH
    mPPHt := mLPHt
    mLPH := mPH
    mLPHt := mPHt

var float mLPL = na
var int mLPLt = na
var float mPPL = na
var int mPPLt = na

if onM1 and not na(mPL)
    mPPL := mLPL
    mPPLt := mLPLt
    mLPL := mPL
    mLPLt := mPLt

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 8. DÉTECTION DES ORDER BLOCKS SOLIDES
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// Algo inspiré VK Trading : ROC impulsif → dernière bougie opposée.
// Filtre ajouté : OB solide = grand corps relatif.

obAtr = ta.atr(obAtrLen)
obAtrPct = close != 0 ? obAtr / close * 100.0 : 0.0
ob1Sens = obSensitivityMode == "ATR adaptive" ? ob1Sensitivity * 0.1 * obAtrPct : ob1Sensitivity * 0.01
ob2Sens = obSensitivityMode == "ATR adaptive" ? ob2Sensitivity * 0.1 * obAtrPct : ob2Sensitivity * 0.01
ob1Pc = (close - close[1]) / close[1] * 100.0
ob2Pc = (open - open[4]) / open[4] * 100.0

// Les fonctions ta.crossover/ta.crossunder dépendent de l'historique.
// Elles sont donc calculées à chaque bougie dans des variables globales,
// puis utilisées dans les conditions OB. Cela évite l'avertissement CW10002.
ob1CrossUp = ta.crossover(ob1Pc, ob1Sens)
ob1CrossDown = ta.crossunder(ob1Pc, -ob1Sens)
ob2CrossUp = ta.crossover(ob2Pc, ob2Sens)
ob2CrossDown = ta.crossunder(ob2Pc, -ob2Sens)

var int[] obDirArr = array.new_int()
var int[] obTimeArr = array.new_int()
var float[] obTopArr = array.new_float()
var float[] obBotArr = array.new_float()
var string[] obSourceArr = array.new_string()

// FVG stockés en continu, comme les OB.
// Problème corrigé v1.2 : avant, le script ne cherchait les FVG qu'après que le Fibo était déjà posé,
// donc il ratait tous les FVG formés pendant la jambe M1.
var int[] fvgDirArr = array.new_int()
var int[] fvgTimeArr = array.new_int()
var float[] fvgTopArr = array.new_float()
var float[] fvgBotArr = array.new_float()

f_push_fvg(int d, int t, float top, float bot) =>
    bool duplicate = false
    int sz = array.size(fvgTimeArr)
    if sz > 0
        duplicate := array.get(fvgTimeArr, sz - 1) == t and array.get(fvgDirArr, sz - 1) == d
    if not duplicate
        array.push(fvgDirArr, d)
        array.push(fvgTimeArr, t)
        array.push(fvgTopArr, top)
        array.push(fvgBotArr, bot)
        if array.size(fvgTimeArr) > 250
            array.shift(fvgDirArr)
            array.shift(fvgTimeArr)
            array.shift(fvgTopArr)
            array.shift(fvgBotArr)

f_push_ob(int d, int t, float top, float bot, string src) =>
    bool duplicate = false
    int sz = array.size(obTimeArr)
    if sz > 0
        duplicate := array.get(obTimeArr, sz - 1) == t and array.get(obDirArr, sz - 1) == d
    if not duplicate
        array.push(obDirArr, d)
        array.push(obTimeArr, t)
        array.push(obTopArr, top)
        array.push(obBotArr, bot)
        array.push(obSourceArr, src)
        if array.size(obTimeArr) > 100
            array.shift(obDirArr)
            array.shift(obTimeArr)
            array.shift(obTopArr)
            array.shift(obBotArr)
            array.shift(obSourceArr)

if onM1 and ob1CrossUp
    bool found = false
    int foundTime = na
    float foundTop = na
    float foundBot = na
    for i = 1 to obLookback1
        if not found and close[i] < open[i] and f_ob_solid(i)
            found := true
            foundTime := time[i]
            foundTop := high[i]
            foundBot := low[i]
    if found
        f_push_ob(1, foundTime, foundTop, foundBot, "OB1")

if onM1 and ob1CrossDown
    bool found = false
    int foundTime = na
    float foundTop = na
    float foundBot = na
    for i = 1 to obLookback1
        if not found and close[i] > open[i] and f_ob_solid(i)
            found := true
            foundTime := time[i]
            foundTop := high[i]
            foundBot := low[i]
    if found
        f_push_ob(-1, foundTime, foundTop, foundBot, "OB1")

if onM1 and ob2CrossUp
    bool found = false
    int foundTime = na
    float foundTop = na
    float foundBot = na
    for i = obLookback2From to obLookback2To
        if not found and close[i] < open[i] and f_ob_solid(i)
            found := true
            foundTime := time[i]
            foundTop := high[i]
            foundBot := low[i]
    if found
        f_push_ob(1, foundTime, foundTop, foundBot, "OB2")

if onM1 and ob2CrossDown
    bool found = false
    int foundTime = na
    float foundTop = na
    float foundBot = na
    for i = obLookback2From to obLookback2To
        if not found and close[i] > open[i] and f_ob_solid(i)
            found := true
            foundTime := time[i]
            foundTop := high[i]
            foundBot := low[i]
    if found
        f_push_ob(-1, foundTime, foundTop, foundBot, "OB2")

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 8B. DÉTECTION CONTINUE DES FVG
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// Les FVG sont stockés en continu, puis sélectionnés plus tard si leur zone tombe dans l'OTE.
// Bullish FVG : low > high[2]. Zone = high[2] → low.
// Bearish FVG : high < low[2]. Zone = high → low[2].

bullFvgRaw = onM1 and low > high[2]
bearFvgRaw = onM1 and high < low[2]

if bullFvgRaw
    f_push_fvg(1, time[2], low, high[2])

if bearFvgRaw
    f_push_fvg(-1, time[2], low[2], high)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 9. VARIABLES DU MOTEUR DE SETUP
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

var int mStt = 0
var bool mBear = false
var float mS1 = na
var int mS1t = na
var float mS2 = na
var int mS2t = na
var float legEnd = na
var int legEndTime = na
var float oteLo = na
var float oteHi = na
var float setupTP = na
var bool pdSelected = false
var bool pdMitigated = false
var int pdDir = 0
var int pdTime = na
var float pdTop = na
var float pdBot = na
var float pdMid = na
var string pdType = ""
var float tradeSL = na
var float tradeTP = na
var int setupCount = 0
var int tradeSignalCount = 0
var float rrSum = 0.0
var int h1SignalCount = 0
var int legCount = 0
var int obSelectedCount = 0
var int fvgSelectedCount = 0
var int pdTouchCount = 0
var int rejectCount = 0
var int riskFailCount = 0

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 10. NOUVEAU SETUP H1 + DOUBLE SWING M15
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// À chaque signal H1, on vérifie les deux derniers pivots M15.
// Bearish : deux swing highs. Bullish : deux swing lows.
// Test C : S2 doit être plus intérieur que S1.

if newSignal
    h1SignalCount += 1
    f_clear_visuals()
    bool sigBear = bearSig and allowBear
    bool sigBull = bullSig and allowBull
    mBear := sigBear
    bool okBearPair = sigBear and not na(mPPH) and not na(mLPH) and (not requireS2InsideS1 or mLPH < mPPH)
    bool okBullPair = sigBull and not na(mPPL) and not na(mLPL) and (not requireS2InsideS1 or mLPL > mPPL)
    if okBearPair
        mS1 := mPPH
        mS1t := mPPHt
        mS2 := mLPH
        mS2t := mLPHt
        mStt := 2
        setupTP := c1l
        setupCount += 1
        pdSelected := false
        pdMitigated := false
        if showDebugVisuals
            line l = line.new(mS1t, mS1, mS2t, mS2, xloc=xloc.bar_time, color=color.blue, width=2, style=line.style_arrow_right)
            label lb1 = label.new(mS1t, mS1, "S1", xloc=xloc.bar_time, yloc=yloc.abovebar, style=label.style_none, textcolor=color.blue)
            label lb2 = label.new(mS2t, mS2, "S2", xloc=xloc.bar_time, yloc=yloc.abovebar, style=label.style_none, textcolor=color.blue)
            label sig = label.new(c2open, c2h, bearC2 ? "Bear C2" : "Bear C3", xloc=xloc.bar_time, yloc=yloc.price, style=label.style_label_down, color=color.red, textcolor=color.white)
            f_add_line(l)
            f_add_label(lb1)
            f_add_label(lb2)
            f_add_label(sig)
    else if okBullPair
        mBear := false
        mS1 := mPPL
        mS1t := mPPLt
        mS2 := mLPL
        mS2t := mLPLt
        mStt := 2
        setupTP := c1h
        setupCount += 1
        pdSelected := false
        pdMitigated := false
        if showDebugVisuals
            line l = line.new(mS1t, mS1, mS2t, mS2, xloc=xloc.bar_time, color=color.blue, width=2, style=line.style_arrow_right)
            label lb1 = label.new(mS1t, mS1, "S1", xloc=xloc.bar_time, yloc=yloc.belowbar, style=label.style_none, textcolor=color.blue)
            label lb2 = label.new(mS2t, mS2, "S2", xloc=xloc.bar_time, yloc=yloc.belowbar, style=label.style_none, textcolor=color.blue)
            label sig = label.new(c2open, c2l, bullC2 ? "Bull C2" : "Bull C3", xloc=xloc.bar_time, yloc=yloc.price, style=label.style_label_up, color=color.green, textcolor=color.white)
            f_add_line(l)
            f_add_label(lb1)
            f_add_label(lb2)
            f_add_label(sig)
    else
        mStt := 0

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 11. INVALIDATION OPTIONNELLE AU-DELÀ DE S2
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// Test A/C : si le prix clôture au-delà de S2 dans le mauvais sens, on annule le setup tant qu'il n'y a pas de position.

if onM1 and invalidateBeyondS2 and mStt >= 2 and strategy.position_size == 0
    if (mBear and close > mS2) or ((not mBear) and close < mS2)
        mStt := 0
        pdSelected := false
        pdMitigated := false

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 12. FIN DE JAMBE M1 ET FIBO / OTE
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// Jambe master : bearish S2 high → premier pivot low M15 opposé ; bullish S2 low → premier pivot high M15 opposé.

if onM1 and mStt == 2
    bool legDone = mBear ? (not na(mPL) and mPLt > mS2t) : (not na(mPH) and mPHt > mS2t)
    if legDone
        legEnd := mBear ? mPL : mPH
        legEndTime := mBear ? mPLt : mPHt
        float p618 = f_level(mS2, legEnd, 0.618)
        float p79 = f_level(mS2, legEnd, oteDeep)
        oteLo := math.min(p618, p79)
        oteHi := math.max(p618, p79)
        mStt := 4
        legCount += 1
        pdSelected := false
        pdMitigated := false
        if showDebugVisuals
            int x2 = legEndTime + fibForwardMinutes * 60000
            line leg = line.new(mS2t, mS2, legEndTime, legEnd, xloc=xloc.bar_time, color=mBear ? color.red : color.lime, width=2, style=line.style_arrow_right)
            f_add_line(leg)
            f_draw_fib(legEndTime, x2, mS2, legEnd)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 13. SÉLECTION D'UN OB SOLIDE DANS L'OTE
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// On scanne les OB détectés entre S2 et la fin de jambe.
// L'OB doit être dans l'OTE ; par défaut, son midpoint doit être dans l'OTE.

if onM1 and mStt == 4 and not pdSelected and (pdMode == "OB solide" or pdMode == "OB solide ou FVG")
    int idx = array.size(obTimeArr) - 1
    while idx >= 0 and not pdSelected
        int d = array.get(obDirArr, idx)
        int t = array.get(obTimeArr, idx)
        float top = array.get(obTopArr, idx)
        float bot = array.get(obBotArr, idx)
        float mid = (top + bot) / 2.0
        bool dirOK = mBear ? d == -1 : d == 1
        bool timeOK = t >= mS2t and t <= legEndTime
        bool zoneOK = pdRequireMidInOTE ? f_in_zone(mid, oteLo, oteHi) : f_zone_overlap(top, bot, oteHi, oteLo)
        if dirOK and timeOK and zoneOK
            pdSelected := true
            pdDir := d
            pdTime := t
            pdTop := top
            pdBot := bot
            pdMid := mid
            pdType := "OB"
            obSelectedCount += 1
            if showDebugVisuals
                box b = box.new(pdTime, pdTop, time + 600000, pdBot, xloc=xloc.bar_time, border_color=mBear ? color.red : color.green, bgcolor=color.new(mBear ? color.red : color.green, 82))
                label lb = label.new(pdTime, pdTop, "OB solide", xloc=xloc.bar_time, yloc=yloc.price, style=label.style_none, textcolor=mBear ? color.red : color.green)
                f_add_box(b)
                f_add_label(lb)
        idx -= 1

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 14. OPTION FVG DANS L'OTE
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// v1.2 : les FVG sont maintenant sélectionnés depuis un registre historique.
// Avant, le code ne regardait que le FVG de la bougie actuelle après le Fibo, ce qui ratait les FVG formés dans la jambe.

if onM1 and mStt == 4 and not pdSelected and (pdMode == "FVG" or pdMode == "OB solide ou FVG")
    int idxF = array.size(fvgTimeArr) - 1
    while idxF >= 0 and not pdSelected
        int d = array.get(fvgDirArr, idxF)
        int t = array.get(fvgTimeArr, idxF)
        float top = array.get(fvgTopArr, idxF)
        float bot = array.get(fvgBotArr, idxF)
        float mid = (top + bot) / 2.0
        bool dirOK = mBear ? d == -1 : d == 1
        bool timeOK = t >= mS2t and t <= legEndTime
        bool zoneOK = pdRequireMidInOTE ? f_in_zone(mid, oteLo, oteHi) : f_zone_overlap(top, bot, oteHi, oteLo)
        if dirOK and timeOK and zoneOK
            pdSelected := true
            pdDir := d
            pdTime := t
            pdTop := top
            pdBot := bot
            pdMid := mid
            pdType := "FVG"
            fvgSelectedCount += 1
            if showDebugVisuals
                box b = box.new(pdTime, pdTop, time + 600000, pdBot, xloc=xloc.bar_time, border_color=mBear ? color.red : color.green, bgcolor=color.new(mBear ? color.red : color.green, 80))
                f_add_box(b)
        idxF -= 1

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 15. MITIGATION + REJET + ORDRE
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// Ordre uniquement si PD Array sélectionné → prix revient le toucher → bougie de rejet dans le sens.
// SL : derrière le PD Array. TP : borne opposée du range H1 initial.

pdTouched = pdSelected and high >= pdBot and low <= pdTop

if onM1 and mStt == 4 and pdSelected and not pdMitigated and pdTouched
    pdMitigated := true
    pdTouchCount += 1

longReject = onM1 and mStt == 4 and pdSelected and pdMitigated and not mBear and close > open and close >= pdMid
shortReject = onM1 and mStt == 4 and pdSelected and pdMitigated and mBear and close < open and close <= pdMid

longSL = pdBot - slBufferTicks * syminfo.mintick
shortSL = pdTop + slBufferTicks * syminfo.mintick
longTP = setupTP
shortTP = setupTP

if longReject or shortReject
    rejectCount += 1

longValidRisk = longReject and longSL < close and longTP > close
shortValidRisk = shortReject and shortSL > close and shortTP < close

if (longReject and not longValidRisk) or (shortReject and not shortValidRisk)
    riskFailCount += 1

if strategy.position_size == 0 and longValidRisk
    float rr = math.abs(longTP - close) / math.abs(close - longSL)
    strategy.entry("LONG", strategy.long, qty=orderQty)
    strategy.exit("LONG EXIT", "LONG", stop=longSL, limit=longTP)
    tradeSignalCount += 1
    rrSum += rr
    mStt := 5
    if showDebugVisuals
        label lb = label.new(time, close, "BUY " + pdType + " RR " + str.tostring(rr, "#.##"), xloc=xloc.bar_time, yloc=yloc.belowbar, style=label.style_label_up, color=color.green, textcolor=color.white)
        f_add_label(lb)

if strategy.position_size == 0 and shortValidRisk
    float rr = math.abs(close - shortTP) / math.abs(shortSL - close)
    strategy.entry("SHORT", strategy.short, qty=orderQty)
    strategy.exit("SHORT EXIT", "SHORT", stop=shortSL, limit=shortTP)
    tradeSignalCount += 1
    rrSum += rr
    mStt := 5
    if showDebugVisuals
        label lb = label.new(time, close, "SELL " + pdType + " RR " + str.tostring(rr, "#.##"), xloc=xloc.bar_time, yloc=yloc.abovebar, style=label.style_label_down, color=color.red, textcolor=color.white)
        f_add_label(lb)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 16. TABLEAU DE SUIVI INTERNE — VERSION PROPRE
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// Table volontairement réduite : elle sert à suivre le backtest sans polluer le graphique.
// Les détails de debug lourd restent disponibles dans la v1.5 diagnostic.

var table stats = table.new(position.top_right, 2, 20)

if showTable
    int closed = strategy.closedtrades
    int wins = strategy.wintrades
    float wr = closed > 0 ? wins * 100.0 / closed : na
    float avgRR = tradeSignalCount > 0 ? rrSum / tradeSignalCount : na
    table.cell(stats, 0, 0, "Ticker", text_color=color.white)
    table.cell(stats, 1, 0, syminfo.ticker, text_color=color.white)
    table.cell(stats, 0, 1, "Type", text_color=color.white)
    table.cell(stats, 1, 1, assetType, text_color=color.white)
    table.cell(stats, 0, 2, "TF", text_color=color.white)
    table.cell(stats, 1, 2, onM1 ? "M1 OK" : "Passe en M1", text_color=onM1 ? color.lime : color.red)
    table.cell(stats, 0, 3, "Mode", text_color=color.white)
    table.cell(stats, 1, 3, strategyMode, text_color=color.white)
    table.cell(stats, 0, 4, "PD Array", text_color=color.white)
    table.cell(stats, 1, 4, pdMode, text_color=color.white)
    table.cell(stats, 0, 5, "H1 signaux", text_color=color.white)
    table.cell(stats, 1, 5, str.tostring(h1SignalCount), text_color=color.white)
    table.cell(stats, 0, 6, "Setups S1/S2", text_color=color.white)
    table.cell(stats, 1, 6, str.tostring(setupCount), text_color=color.white)
    table.cell(stats, 0, 7, "Jambes/Fibo", text_color=color.white)
    table.cell(stats, 1, 7, str.tostring(legCount), text_color=color.white)
    table.cell(stats, 0, 8, "OB / FVG choisis", text_color=color.white)
    table.cell(stats, 1, 8, str.tostring(obSelectedCount) + " / " + str.tostring(fvgSelectedCount), text_color=color.white)
    table.cell(stats, 0, 9, "Touch / Rejet", text_color=color.white)
    table.cell(stats, 1, 9, str.tostring(pdTouchCount) + " / " + str.tostring(rejectCount), text_color=color.white)
    table.cell(stats, 0, 10, "Risk fails", text_color=color.white)
    table.cell(stats, 1, 10, str.tostring(riskFailCount), text_color=riskFailCount > 0 ? color.orange : color.gray)
    table.cell(stats, 0, 11, "Signaux trade", text_color=color.white)
    table.cell(stats, 1, 11, str.tostring(tradeSignalCount), text_color=color.white)
    table.cell(stats, 0, 12, "Trades fermés", text_color=color.white)
    table.cell(stats, 1, 12, str.tostring(closed), text_color=color.white)
    table.cell(stats, 0, 13, "Trades ouverts", text_color=color.white)
    table.cell(stats, 1, 13, str.tostring(strategy.opentrades), text_color=strategy.opentrades > 0 ? color.orange : color.gray)
    table.cell(stats, 0, 14, "Position", text_color=color.white)
    table.cell(stats, 1, 14, str.tostring(strategy.position_size), text_color=strategy.position_size != 0 ? color.orange : color.gray)
    table.cell(stats, 0, 15, "Winrate", text_color=color.white)
    table.cell(stats, 1, 15, na(wr) ? "na" : str.tostring(wr, "#.##") + "%", text_color=color.white)
    table.cell(stats, 0, 16, "RR moyen signal", text_color=color.white)
    table.cell(stats, 1, 16, na(avgRR) ? "na" : str.tostring(avgRR, "#.##"), text_color=color.white)
    table.cell(stats, 0, 17, "Net profit", text_color=color.white)
    table.cell(stats, 1, 17, str.tostring(strategy.netprofit, "#.##"), text_color=strategy.netprofit >= 0 ? color.lime : color.red)
    table.cell(stats, 0, 18, "Order qty", text_color=color.white)
    table.cell(stats, 1, 18, str.tostring(orderQty), text_color=color.white)
    table.cell(stats, 0, 19, "État moteur", text_color=color.white)
    table.cell(stats, 1, 19, str.tostring(mStt), text_color=color.white)
