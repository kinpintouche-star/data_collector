        </mxCell>
        <mxCell id="current-limits" value="Limites / decisions actuelles&#xa;- Postgres local reste la base canonique.&#xa;- Neon sert de buffer recent ~30 jours, pas de source principale de backtest.&#xa;- 180 jours+ restent locaux tant qu'une archive remote compressee n'est pas ajoutee.&#xa;- GitHub Actions est le collecteur remote officiel.&#xa;- Oracle VM / Docker remote / Cloudflare sont legacy.&#xa;- OANDA est retire du pipeline operationnel." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fefce8;strokeColor=#ca8a04;fontSize=12;align=left;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="480" y="880" width="540" height="120" as="geometry" />
        </mxCell>
        <mxCell id="update-rule" value="Regle de maintenance&#xa;Quand un service, un container, une source de donnees ou un flux critique change, mettre a jour:&#xa;1. docs/ARCHITECTURE_CURRENT.drawio&#xa;2. docs/ARCHITECTURE.md&#xa;3. docs/PROJECT_NOW.md / PROJECT_THREAD.md si le jalon change" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfeff;strokeColor=#0891b2;fontSize=12;align=left;spacing=8;" vertex="1" parent="1">
