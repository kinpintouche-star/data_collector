        <mxCell id="legend" value="Legende&#xa;Trait plein: chemin principal runtime&#xa;Trait pointille: chemin admin/sync/backfill&#xa;Orange: stockage canonique&#xa;Bleu/vert: API/UI&#xa;Violet: acquisition externe" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#94a3b8;fontSize=12;align=left;spacing=8;" vertex="1" parent="1">
