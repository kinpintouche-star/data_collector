LIVE_REMOTE_DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Optional: leave empty for all enabled assets in configs/live_sources.yaml.
LIVE_COLLECTOR_SYMBOLS=

# Rolling collector: recent completed M1 candles, pushed to Neon every hour.
LIVE_COLLECTOR_INTERVAL_SECONDS=3600
LIVE_COLLECTOR_LOOKBACK_MINUTES=180
LIVE_COLLECTOR_SAFETY_DELAY_MINUTES=3

# Daily repair collector: refetches complete UTC days to close gaps.
LIVE_COLLECTOR_DAILY_UTC_HOUR=2
LIVE_COLLECTOR_DAILY_UTC_MINUTE=17
LIVE_COLLECTOR_BACKFILL_DAYS=3

# Provider/Neon pressure controls.
LIVE_COLLECTOR_MAX_WORKERS=4
LIVE_COLLECTOR_UPLOAD_CHUNK_ROWS=2500
LIVE_COLLECTOR_SUBMIT_PAUSE_SECONDS=0.35

LIVE_COLLECTOR_RUN_ON_START=true
LIVE_COLLECTOR_REPAIR_RUN_ON_START=true
